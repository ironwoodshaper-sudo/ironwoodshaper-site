{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/outputs/index.html"
    },
    {
      "source": "/styles.css",
      "destination": "/outputs/styles.css"
    },
    {
      "source": "/script.js",
      "destination": "/outputs/script.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/outputs/assets/:path*"
    },
    {
      "source": "/data/:path*",
      "destination": "/outputs/data/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
